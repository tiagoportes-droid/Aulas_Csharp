Console.WriteLine("=== VERIFICADOR DE NÚMERO PRIMO ===");
Console.Write("Digite um número: ");

// Lê a entrada do usuário
string entrada = Console.ReadLine() ?? "";

if (int.TryParse(entrada, out int numero))
{
    int totalDivisores = 0;

    // Um número primo só é divisível por 1 e por ele mesmo
    for (int i = 1; i <= numero; i++)
    {
        if (numero % i == 0)
        {
            totalDivisores++;
        }
    }

    if (totalDivisores == 2)
    {
        Console.WriteLine($"💎 O número {numero} é PRIMO!");
    }
    else
    {
        Console.WriteLine($"❌ O número {numero} NÃO é primo.");
    }
}
else
{
    Console.WriteLine("Isso não parece um número válido.");
}
